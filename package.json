{
  "name": "everything-mcp",
  "version": "1.0.0",
  "description": "MCP server for Everything search using ffi-rs and the Everything SDK",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "everything-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "postinstall": "echo 'Make sure Everything is running before using this MCP server'"
  },
  "keywords": ["everything", "search", "mcp", "model-context-protocol"],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ffi-rs": "^1.3.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
